{
  "name": "trillick-autoparts",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test && npm run test:e2e",
    "audit:security": "npm audit --audit-level=moderate",
    "extract": "python3 scripts/extract-catalogue.py",
    "scrape": "tsx scripts/scrape-site.ts",
    "merge": "tsx scripts/merge-products.ts",
    "seed": "tsx scripts/seed-db.ts",
    "assign-prices": "tsx scripts/assign-prices.ts",
    "ingest": "npm run extract && npm run scrape && npm run merge && npm run assign-prices && npm run seed",
    "postinstall": "node -e \"const fs=require('fs');const p='data/products.json';if(!fs.existsSync(p)&&fs.existsSync('data/sample-products.json'))fs.copyFileSync('data/sample-products.json',p)\""
  },
  "dependencies": {
    "@supabase/supabase-js": "2.110.0",
    "cheerio": "1.2.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "fuse.js": "7.4.2",
    "lucide-react": "1.23.0",
    "meilisearch": "0.58.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "22.3.0",
    "tailwind-merge": "3.6.0",
    "tsx": "4.22.4",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "29.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.9"
  }
}
